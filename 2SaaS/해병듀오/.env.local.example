# 로컬 supabase (supabase start 후 `supabase status`로 키 조회)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# 서버 전용 (절대 NEXT_PUBLIC_ 붙이지 말 것 — 클라이언트 노출 금지)
SUPABASE_SERVICE_ROLE_KEY=

# Android NotificationListenerService / MessengerBotR 카톡 알림 수집용
# 운영에서는 긴 랜덤값 사용. 로컬 개발에서는 미설정 시 dev-kakao-test-token 허용.
KAKAO_NOTIFICATION_INGEST_TOKEN=

# AIP / LLM 초안 생성용. 서버 전용이며 NEXT_PUBLIC_ 접두사 금지.
# auto는 Kimi 키가 있으면 Kimi를 우선 사용하고, 없으면 OpenAI, 둘 다 없으면 룰 기반 fallback으로 동작한다.
AIP_PROVIDER=auto
KIMI_API_KEY=
KIMI_MODEL=kimi-k2.5
KIMI_THINKING=disabled
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
AIP_DISABLE_LLM=false

# 카톡 알림 자동 수집 중 LLM으로 퀘스트 제목/내용을 보강할지 여부.
# 비용·지연 방지를 위해 기본은 false. 수동 포워딩/수동 제안 생성은 키가 있으면 LLM을 사용한다.
AIP_ENABLE_KAKAO_PROPOSAL_AI=false

# Google Calendar / Tasks 개인 계정 OAuth 연동용.
# GOOGLE_TOKEN_ENCRYPTION_KEY는 `openssl rand -base64 32` 같은 긴 랜덤값 사용.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_TOKEN_ENCRYPTION_KEY=

# Google Sheets 본사 운영시트 read-only 동기화용.
# GOOGLE_SERVICE_ACCOUNT_KEY는 서비스 계정 JSON 전체를 한 줄 문자열로 넣는다.
GOOGLE_SERVICE_ACCOUNT_KEY=
SHEET_ID_BIZHIGH=117u2PT14pZrpAeYsk8GpPItQtAU9rNygJ9CQUnXhpbI
SHEET_SYNC_INTERVAL_MIN=5

# Vercel Cron 보호용. 운영에서는 긴 랜덤값 사용.
CRON_SECRET=
